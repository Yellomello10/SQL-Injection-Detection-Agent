# ================================
# SQL Injection Detection Agent
# Environment Configuration
# ================================

# Anthropic API Key (optional if using Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Gemini API Key (required for Gemini agents)
GEMINI_API_KEY=your_gemini_api_key_here

# Target API Configuration
TARGET_API_HOST=localhost
TARGET_API_PORT=5000
TARGET_API_BASE_URL=http://localhost:5000

# MySQL Database Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=sqli_user
MYSQL_PASSWORD=sqli_password
MYSQL_DATABASE=sqli_testdb
MYSQL_ROOT_PASSWORD=root_password

# Agent Configuration
AGENT_MAX_TOKENS=8192
AGENT_MAX_ITERATIONS=50
AGENT_REQUEST_TIMEOUT=30
AGENT_RETRY_ATTEMPTS=3
AGENT_RETRY_DELAY=1.0

# Time-based SQLi Detection Threshold (seconds)
TIME_BASED_THRESHOLD=3.0

# Report Output Directory
REPORT_OUTPUT_DIR=./reports

# Logging Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
